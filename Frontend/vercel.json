{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sanitaryware-xu94.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://sanitaryware-xu94.onrender.com/uploads/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://sanitaryware-xu94.onrender.com/api/media/:path*"
    },
    {
      "source": "/api",
      "destination": "https://sanitaryware-xu94.onrender.com/api"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
}
